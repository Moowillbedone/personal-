# Set these in Vercel project settings (Settings → Environment Variables)
# and locally in .env.local for development.

# ── existing (signal tracker) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...   # anon (public) key only

# ── added for /trade feature (server-side only) ───────────
# Service-role key — used by API routes to write watchlist / positions / ai_analysis.
# NEVER expose to the browser. Do NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Alpaca (free IEX feed) — for snapshots, news, intraday bars.
ALPACA_KEY_ID=PK...
ALPACA_SECRET=...

# Google AI Studio (Gemini Flash, free tier) — for /api/analyze.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# Recommended: gemini-2.5-flash. Fallback: gemini-flash-latest
GEMINI_MODEL=gemini-2.5-flash

# ── Optional macro/fundamental data sources (analyzer auto-skips if absent) ──
# FRED (US macro indicators: 10Y yield, DXY, VIX, CPI, unemployment)
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=

# Finnhub (analyst consensus + earnings calendar + earnings surprises)
# Free 60 calls/min: https://finnhub.io/register
# FINNHUB_API_KEY=
